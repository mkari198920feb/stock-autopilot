# Optional: enables LLM-powered news synthesis (otherwise rule-based)
OPENAI_API_KEY=

# Autopilot schedule (24h clock, UTC). Default 13:30 = after US pre-market research window
AUTOPILOT_HOUR=13
AUTOPILOT_MINUTE=30

# Target annual return band for screening (not a guarantee)
# Override per user via dashboard Settings, or use single target:
# TARGET_RETURN_MIN=0.10
# TARGET_RETURN_MAX=0.20
TARGET_RETURN_MIN=0.12
TARGET_RETURN_MAX=0.15

# ── Daily email to friends ─────────────────────────────────────────────
EMAIL_ENABLED=true

# Comma-separated (optional — also add emails in config.yaml)
EMAIL_RECIPIENTS=friend1@gmail.com,friend2@gmail.com

# Gmail example (use an App Password, not your normal password)
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=your.email@gmail.com

# Optional link included in emails
DASHBOARD_URL=http://127.0.0.1:8080

# When auth.enabled=true in config.yaml, your reverse proxy / IAM federation should send:
# X-LUMIQ-User: user@company.com
# X-LUMIQ-Roles: admin,analyst
